# AI provider: anthropic | openai | azure | mistral | ollama
AI_PROVIDER=mistral

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# Optional. Defaults to backend/data locally and /tmp on Vercel.
DATABASE_PATH=
UPLOAD_DIR=

# Comma-separated list for deployed backends that are called cross-origin.
BACKEND_CORS_ORIGINS=
